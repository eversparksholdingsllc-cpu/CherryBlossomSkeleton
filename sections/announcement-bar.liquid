{% if section.settings.show_bar %}
  <div
    class="announcement-bar"
    style="
      --announcement-background: {{ section.settings.background_color }};
      --announcement-text: {{ section.settings.text_color }};
    "
  >
    <div class="announcement-bar__inner">
      {% if section.settings.link != blank %}
        <a href="{{ section.settings.link }}">
          {{ section.settings.text | escape }}
        </a>
      {% else %}
        <p>{{ section.settings.text | escape }}</p>
      {% endif %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .announcement-bar {
    width: 100%;
    background: var(--announcement-background);
    color: var(--announcement-text);
  }

  .announcement-bar__inner {
    width: min(100% - 32px, 1400px);
    margin: 0 auto;
    padding: 10px 16px;
    text-align: center;
  }

  .announcement-bar p,
  .announcement-bar a {
    margin: 0;
    color: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .announcement-bar a:hover {
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free shipping on orders over $75"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Optional link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f3d6e2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}