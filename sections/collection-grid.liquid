<section
  class="collection-grid"
  style="
    --grid-background: {{ section.settings.background_color }};
    --grid-text: {{ section.settings.text_color }};
  "
>

  <div class="collection-grid__inner">

    {% if section.settings.heading != blank %}
      <div class="collection-grid__header">
        <h2 class="collection-grid__heading">
          {{ section.settings.heading }}
        </h2>

        {% if section.settings.description != blank %}
          <div class="collection-grid__description">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>
    {% endif %}


    <div class="collection-grid__items">

      {% for block in section.blocks %}

        <article class="collection-grid__card" {{ block.shopify_attributes }}>

          {% if block.settings.image_desktop != blank or block.settings.image_mobile != blank %}

            <picture>

              {% if block.settings.image_mobile != blank %}
                <source
                  media="(max-width: 749px)"
                  srcset="{{ block.settings.image_mobile | image_url: width: 700 }}"
                >
              {% endif %}


              {% if block.settings.image_desktop != blank %}
                {{
                  block.settings.image_desktop
                  | image_url: width: 1000
                  | image_tag:
                    class: 'collection-grid__image',
                    loading: 'lazy',
                    widths: '400,600,800,1000',
                    sizes: '(min-width: 750px) 33vw, 100vw',
                    alt: block.settings.image_desktop.alt
                }}
              {% endif %}

            </picture>

          {% endif %}


          <div class="collection-grid__card-content">

            {% if block.settings.title != blank %}
              <h3>
                {{ block.settings.title }}
              </h3>
            {% endif %}


            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}">
                {{ block.settings.button_text }}
              </a>
            {% endif %}

          </div>


        </article>

      {% endfor %}

    </div>

  </div>

</section>
{% stylesheet %}

  .collection-grid {
    width: 100%;
    padding: 72px 0;
    background: var(--grid-background);
    color: var(--grid-text);
  }


  .collection-grid__inner {
    width: min(100% - 32px, 1400px);
    margin: 0 auto;
  }


  .collection-grid__header {
    margin-bottom: 42px;
    text-align: center;
  }


  .collection-grid__heading {
    margin: 0;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.05;
  }


  .collection-grid__description {
    max-width: 700px;
    margin: 18px auto 0;
    line-height: 1.7;
    opacity: 0.8;
  }


  .collection-grid__items {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }


  .collection-grid__card {
    position: relative;
    overflow: hidden;
    min-height: 420px;
    border-radius: 24px;
    background: rgba(255,255,255,0.4);
  }


  .collection-grid__card picture,
  .collection-grid__image {
    display: block;
    width: 100%;
    height: 100%;
  }


  .collection-grid__image {
    min-height: 420px;
    object-fit: cover;
    transition: transform 300ms ease;
  }


  .collection-grid__card:hover .collection-grid__image {
    transform: scale(1.04);
  }


  .collection-grid__card-content {
    position: absolute;
    inset: auto 0 0;
    padding: 28px;
    background: linear-gradient(
      transparent,
      rgba(0,0,0,0.55)
    );
    color: white;
  }


  .collection-grid__card-content h3 {
    margin: 0 0 12px;
    font-size: 1.7rem;
  }


  .collection-grid__card-content a {
    display: inline-flex;
    padding: 10px 22px;
    border-radius: 999px;
    background: white;
    color: #402733;
    text-decoration: none;
    font-weight: 700;
  }



  @media screen and (max-width: 989px) {

    .collection-grid__items {
      grid-template-columns: repeat(2, 1fr);
    }

  }



  @media screen and (max-width: 749px) {

    .collection-grid {
      padding: 52px 0;
    }


    .collection-grid__items {
      grid-template-columns: 1fr;
      gap: 20px;
    }


    .collection-grid__card {
      min-height: 360px;
      border-radius: 20px;
    }


    .collection-grid__image {
      min-height: 360px;
    }


    .collection-grid__card-content {
      padding: 22px;
    }

  }


{% endstylesheet %}
{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "class": "section-collection-grid",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Explore our collections"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Showcase your favorite collections.</p>"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFF9FC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Desktop card image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile card image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card title",
          "default": "Collection name"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid",
      "blocks": [
        {
          "type": "collection_card"
        },
        {
          "type": "collection_card"
        },
        {
          "type": "collection_card"
        }
      ]
    }
  ]
}
{% endschema %}
