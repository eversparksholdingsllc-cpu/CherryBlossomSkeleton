<section
  class="collection-grid"
  style="
    --collection-grid-background: {{ section.settings.background_color }};
    --collection-grid-text: {{ section.settings.text_color }};
    --collection-grid-columns: {{ section.settings.columns_desktop }};
  "
>
  <div class="collection-grid__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="collection-grid__eyebrow">
        {{ section.settings.eyebrow | escape }}
      </p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="collection-grid__heading">
        {{ section.settings.heading | escape }}
      </h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="collection-grid__description">
        {{ section.settings.description }}
      </div>
    {% endif %}

    <div class="collection-grid__items">
      {% for collection in section.settings.collection_list %}
        <a class="collection-card" href="{{ collection.url }}">
          <div class="collection-card__media">
            {% if collection.featured_image != blank %}
              {{
                collection.featured_image
                | image_url: width: 1200
                | image_tag:
                  class: 'collection-card__image',
                  loading: 'lazy',
                  widths: '400, 600, 800, 1000, 1200',
                  sizes: '(min-width: 990px) 33vw, 50vw',
                  alt: collection.title
              }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'collection-card__placeholder' }}
            {% endif %}

            <div class="collection-card__overlay"></div>

            <div class="collection-card__content">
              <h3>{{ collection.title | escape }}</h3>

              {% if section.settings.show_product_count %}
                <p>
                  {{ collection.products_count }}
                  {% if collection.products_count == 1 %}
                    product
                  {% else %}
                    products
                  {% endif %}
                </p>
              {% endif %}
            </div>
          </div>
        </a>
      {% else %}
        {% for placeholder_number in (1..3) %}
          <div class="collection-card">
            <div class="collection-card__media">
              {{ 'collection-1' | placeholder_svg_tag: 'collection-card__placeholder' }}

              <div class="collection-card__overlay"></div>

              <div class="collection-card__content">
                <h3>Collection {{ placeholder_number }}</h3>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .collection-grid {
    width: 100%;
    padding: 72px 0;
    background: var(--collection-grid-background);
    color: var(--collection-grid-text);
  }

  .collection-grid__inner {
    width: min(100% - 32px, 1400px);
    margin: 0 auto;
  }

  .collection-grid__eyebrow {
    margin: 0 0 10px;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .collection-grid__heading {
    margin: 0;
    text-align: center;
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 1.05;
  }

  .collection-grid__description {
    max-width: 650px;
    margin: 16px auto 36px;
    text-align: center;
    line-height: 1.6;
    opacity: 0.78;
  }

  .collection-grid__description p {
    margin: 0;
  }

  .collection-grid__items {
    display: grid;
    grid-template-columns: repeat(var(--collection-grid-columns), minmax(0, 1fr));
    gap: 24px;
    margin-top: 36px;
  }

  .collection-card {
    color: inherit;
    text-decoration: none;
  }

  .collection-card__media {
    position: relative;
    min-height: 440px;
    overflow: hidden;
    border-radius: 24px;
    background: rgba(0, 0, 0, 0.06);
  }

  .collection-card__image,
  .collection-card__placeholder {
    width: 100%;
    height: 100%;
    min-height: 440px;
    object-fit: cover;
    transition: transform 350ms ease;
  }

  .collection-card:hover .collection-card__image {
    transform: scale(1.04);
  }

  .collection-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(34, 19, 26, 0.7),
      rgba(34, 19, 26, 0.05) 60%
    );
  }

  .collection-card__content {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    padding: 28px;
    color: white;
  }

  .collection-card__content h3 {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
  }

  .collection-card__content p {
    margin: 7px 0 0;
    opacity: 0.85;
  }

  @media screen and (max-width: 989px) {
    .collection-grid__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }
  }

  @media screen and (max-width: 749px) {
    .collection-grid {
      padding: 52px 0;
    }

    .collection-grid__items {
      grid-template-columns: 1fr;
    }

    .collection-card__media,
    .collection-card__image,
    .collection-card__placeholder {
      min-height: 380px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-card__image {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection grid",
  "tag": "section",
  "class": "section-collection-grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small heading",
      "default": "Browse by category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop our collections"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Help customers quickly find the products they love.</p>"
    },
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "Collections",
      "limit": 6
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ],
  "presets": [
    {
      "name": "Collection grid"
    }
  ]
}
{% endschema %}
