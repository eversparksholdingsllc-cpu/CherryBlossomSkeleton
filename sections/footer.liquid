<footer
  class="site-footer"
  style="
    --footer-background: {{ section.settings.background_color }};
    --footer-text: {{ section.settings.text_color }};
  "
>
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <a class="site-footer__logo" href="{{ routes.root_url }}">
          {% if section.settings.logo != blank %}
            {{
              section.settings.logo
              | image_url: width: section.settings.logo_width
              | image_tag:
                loading: 'lazy',
                widths: '100, 150, 200, 250, 300, 400',
                alt: shop.name
            }}
          {% else %}
            {{ shop.name | escape }}
          {% endif %}
        </a>

        {% if section.settings.description != blank %}
          <div class="site-footer__description">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>

      {% for block in section.blocks %}
        <div
          class="site-footer__column"
          {{ block.shopify_attributes }}
        >
          {% case block.type %}
            {% when 'menu' %}
              {% if block.settings.heading != blank %}
                <h2 class="site-footer__heading">
                  {{ block.settings.heading | escape }}
                </h2>
              {% endif %}

              {% if block.settings.menu != blank %}
                <nav aria-label="{{ block.settings.heading | escape }}">
                  <ul class="site-footer__menu">
                    {% for link in block.settings.menu.links %}
                      <li>
                        <a href="{{ link.url }}">
                          {{ link.title | escape }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </nav>
              {% endif %}

            {% when 'text' %}
              {% if block.settings.heading != blank %}
                <h2 class="site-footer__heading">
                  {{ block.settings.heading | escape }}
                </h2>
              {% endif %}

              {% if block.settings.text != blank %}
                <div class="site-footer__text">
                  {{ block.settings.text }}
                </div>
              {% endif %}

            {% when 'newsletter' %}
              {% if block.settings.heading != blank %}
                <h2 class="site-footer__heading">
                  {{ block.settings.heading | escape }}
                </h2>
              {% endif %}

              {% if block.settings.text != blank %}
                <div class="site-footer__text">
                  {{ block.settings.text }}
                </div>
              {% endif %}

              {% form 'customer', class: 'site-footer__newsletter-form' %}
                <input
                  type="hidden"
                  name="contact[tags]"
                  value="newsletter"
                >

                <label class="visually-hidden" for="FooterEmail-{{ section.id }}">
                  Email address
                </label>

                <div class="site-footer__newsletter-field">
                  <input
                    id="FooterEmail-{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    value="{{ form.email }}"
                    placeholder="Email address"
                    autocomplete="email"
                    autocorrect="off"
                    autocapitalize="off"
                    required
                  >

                  <button type="submit">
                    Subscribe
                  </button>
                </div>

                {% if form.posted_successfully? %}
                  <p class="site-footer__message">
                    Thanks for subscribing.
                  </p>
                {% endif %}

                {% if form.errors %}
                  <div class="site-footer__message">
                    {{ form.errors | default_errors }}
                  </div>
                {% endif %}
              {% endform %}
          {% endcase %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_social_links %}
      <div class="site-footer__social">
        {% if settings.social_instagram_link != blank %}
          <a href="{{ settings.social_instagram_link }}">
            Instagram
          </a>
        {% endif %}

        {% if settings.social_tiktok_link != blank %}
          <a href="{{ settings.social_tiktok_link }}">
            TikTok
          </a>
        {% endif %}

        {% if settings.social_facebook_link != blank %}
          <a href="{{ settings.social_facebook_link }}">
            Facebook
          </a>
        {% endif %}

        {% if settings.social_pinterest_link != blank %}
          <a href="{{ settings.social_pinterest_link }}">
            Pinterest
          </a>
        {% endif %}
      </div>
    {% endif %}

    <div class="site-footer__bottom">
      <p>
        &copy; {{ 'now' | date: '%Y' }}
        {{ shop.name | escape }}.
      </p>

      {% if section.settings.show_payment_icons %}
        <div class="site-footer__payments">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    width: 100%;
    padding: 64px 0 24px;
    background: var(--footer-background);
    color: var(--footer-text);
  }

  .site-footer__inner {
    width: min(100% - 32px, 1400px);
    margin: 0 auto;
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: minmax(220px, 1.4fr) repeat(3, minmax(150px, 1fr));
    gap: 44px;
  }

  .site-footer a {
    color: inherit;
    text-decoration: none;
  }

  .site-footer a:hover {
    text-decoration: underline;
  }

  .site-footer__logo {
    display: inline-flex;
    align-items: center;
    font-size: 1.4rem;
    font-weight: 700;
  }

  .site-footer__logo img {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
  }

  .site-footer__description,
  .site-footer__text {
    margin-top: 18px;
    line-height: 1.7;
    opacity: 0.78;
  }

  .site-footer__description p,
  .site-footer__text p {
    margin: 0 0 1em;
  }

  .site-footer__heading {
    margin: 0 0 18px;
    font-size: 1rem;
  }

  .site-footer__menu {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer__newsletter-field {
    display: flex;
    margin-top: 18px;
    overflow: hidden;
    border: 1px solid currentColor;
    border-radius: 999px;
  }

  .site-footer__newsletter-field input {
    min-width: 0;
    flex: 1;
    padding: 13px 18px;
    border: 0;
    outline: 0;
    background: transparent;
    color: inherit;
  }

  .site-footer__newsletter-field button {
    padding: 12px 20px;
    border: 0;
    background: var(--footer-text);
    color: var(--footer-background);
    font-weight: 700;
    cursor: pointer;
  }

  .site-footer__message {
    margin: 12px 0 0;
    font-size: 0.9rem;
  }

  .site-footer__social {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 44px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .site-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    font-size: 0.88rem;
  }

  .site-footer__bottom p {
    margin: 0;
  }

  .site-footer__payments {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
  }

  .site-footer__payments svg {
    width: 38px;
    height: auto;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  @media screen and (max-width: 989px) {
    .site-footer__top {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .site-footer {
      padding-top: 48px;
    }

    .site-footer__top {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .site-footer__bottom {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-footer__payments {
      justify-content: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "section-footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 160
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Brand description",
      "default": "<p>Share a short message about your brand and what makes your shop special.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_social_links",
      "label": "Show social media links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f3d6e2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "About"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add contact details, opening hours, or additional information.</p>"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Join our newsletter"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Receive new-product updates, special offers, and inspiration.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "menu"
        },
        {
          "type": "text"
        },
        {
          "type": "newsletter"
        }
      ]
    }
  ]
}
{% endschema %}
