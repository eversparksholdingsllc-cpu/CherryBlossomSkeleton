{% liquid
  assign featured_collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show
%}

<section
  class="featured-collection"
  style="
    --featured-background: {{ section.settings.background_color }};
    --featured-text: {{ section.settings.text_color }};
    --featured-columns-desktop: {{ section.settings.columns_desktop }};
  "
>
  <div class="featured-collection__inner">
    <div class="featured-collection__header">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="featured-collection__eyebrow">
            {{ section.settings.eyebrow | escape }}
          </p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="featured-collection__heading">
            {{ section.settings.heading | escape }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="featured-collection__description">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>

      {% if section.settings.show_view_all and featured_collection != blank %}
        <a
          class="featured-collection__view-all featured-collection__view-all--desktop"
          href="{{ featured_collection.url }}"
        >
          {{ section.settings.view_all_text | escape }}
        </a>
      {% endif %}
    </div>

    {% if featured_collection != blank and featured_collection.products_count > 0 %}
      <div class="featured-collection__grid">
        {% for product in featured_collection.products limit: products_to_show %}
          <article class="product-card">
            <a class="product-card__image-link" href="{{ product.url }}">
              <div class="product-card__image-wrapper">
                {% if product.featured_image != blank %}
                  {{
                    product.featured_image
                    | image_url: width: 900
                    | image_tag:
                      class: 'product-card__image',
                      loading: 'lazy',
                      widths: '300, 450, 600, 750, 900',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
                      alt: product.featured_image.alt
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder' }}
                {% endif %}

                {% unless product.available %}
                  <span class="product-card__badge">
                    Sold out
                  </span>
                {% endunless %}
              </div>
            </a>

            <div class="product-card__content">
              {% if section.settings.show_vendor and product.vendor != blank %}
                <p class="product-card__vendor">
                  {{ product.vendor | escape }}
                </p>
              {% endif %}

              <h3 class="product-card__title">
                <a href="{{ product.url }}">
                  {{ product.title | escape }}
                </a>
              </h3>

              <div class="product-card__price">
                {% if product.compare_at_price > product.price %}
                  <span class="product-card__price-sale">
                    {{ product.price | money }}
                  </span>

                  <s class="product-card__price-compare">
                    {{ product.compare_at_price | money }}
                  </s>
                {% else %}
                  <span>
                    {{ product.price | money }}
                  </span>
                {% endif %}
              </div>
            </div>
          </article>
        {% endfor %}
      </div>

      {% if section.settings.show_view_all %}
        <div class="featured-collection__mobile-button">
          <a
            class="featured-collection__view-all"
            href="{{ featured_collection.url }}"
          >
            {{ section.settings.view_all_text | escape }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="featured-collection__empty">
        <p>Select a collection in the Theme Editor to display products.</p>

        <div class="featured-collection__grid">
          {% for placeholder_number in (1..4) %}
            <article class="product-card">
              <div class="product-card__image-wrapper">
                {{ 'product-' | append: placeholder_number | placeholder_svg_tag: 'product-card__placeholder' }}
              </div>

              <div class="product-card__content">
                <h3 class="product-card__title">
                  Example product
                </h3>

                <div class="product-card__price">
                  {{ 2500 | money }}
                </div>
              </div>
            </article>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .featured-collection {
    width: 100%;
    padding: 72px 0;
    background: var(--featured-background);
    color: var(--featured-text);
  }

  .featured-collection__inner {
    width: min(100% - 32px, 1400px);
    margin: 0 auto;
  }

  .featured-collection__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: 34px;
  }

  .featured-collection__eyebrow {
    margin: 0 0 10px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .featured-collection__heading {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 1.05;
  }

  .featured-collection__description {
    max-width: 650px;
    margin-top: 15px;
    line-height: 1.6;
    opacity: 0.78;
  }

  .featured-collection__description p {
    margin: 0;
  }

  .featured-collection__grid {
    display: grid;
    grid-template-columns: repeat(var(--featured-columns-desktop), minmax(0, 1fr));
    gap: 24px;
  }

  .product-card {
    min-width: 0;
  }

  .product-card a {
    color: inherit;
    text-decoration: none;
  }

  .product-card__image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    border-radius: 20px;
    background: rgba(0, 0, 0, 0.04);
  }

  .product-card__image,
  .product-card__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease;
  }

  .product-card__image-link:hover .product-card__image {
    transform: scale(1.035);
  }

  .product-card__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    padding: 7px 11px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: #3e2932;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .product-card__content {
    padding-top: 16px;
  }

  .product-card__vendor {
    margin: 0 0 5px;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .product-card__title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.35;
  }

  .product-card__price {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
    font-size: 0.95rem;
  }

  .product-card__price-sale {
    font-weight: 700;
  }

  .product-card__price-compare {
    opacity: 0.55;
  }

  .featured-collection__view-all {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 10px 24px;
    border: 1px solid currentColor;
    border-radius: 999px;
    color: inherit;
    text-decoration: none;
    font-weight: 700;
  }

  .featured-collection__view-all:hover {
    background: var(--featured-text);
    color: var(--featured-background);
  }

  .featured-collection__mobile-button {
    display: none;
    margin-top: 30px;
    text-align: center;
  }

  .featured-collection__empty > p {
    margin: 0 0 24px;
    text-align: center;
  }

  @media screen and (max-width: 989px) {
    .featured-collection__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }
  }

  @media screen and (max-width: 749px) {
    .featured-collection {
      padding: 52px 0;
    }

    .featured-collection__header {
      display: block;
      margin-bottom: 26px;
    }

    .featured-collection__view-all--desktop {
      display: none;
    }

    .featured-collection__mobile-button {
      display: block;
    }

    .product-card__image-wrapper {
      border-radius: 14px;
    }
  }

  @media screen and (max-width: 420px) {
    .featured-collection__grid {
      gap: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card__image {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small heading",
      "default": "Shop our favorites"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured collection"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Highlight your newest arrivals, best sellers, or seasonal favorites.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all button text",
      "default": "View all"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fffafc"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
