<section
  class="featured-collection"
  style="
    --featured-background: {{ section.settings.background_color }};
    --featured-text: {{ section.settings.text_color }};
    --featured-height: {{ section.settings.section_height }}px;
    --featured-height-mobile: {{ section.settings.section_height_mobile }}px;
  "
>

  <div class="featured-collection__inner">

    {% if section.settings.image_desktop != blank or section.settings.image_mobile != blank %}

      <div class="featured-collection__banner">

        <picture>

          {% if section.settings.image_mobile != blank %}
            <source
              media="(max-width: 749px)"
              srcset="{{ section.settings.image_mobile | image_url: width: 1000 }}"
            >
          {% endif %}


          {% if section.settings.image_desktop != blank %}
            {{
              section.settings.image_desktop
              | image_url: width: 2000
              | image_tag:
                class: 'featured-collection__image',
                loading: 'lazy',
                widths: '750,1000,1500,2000',
                sizes: '100vw',
                alt: section.settings.image_desktop.alt
            }}
          {% endif %}

        </picture>

      </div>

    {% endif %}



    <div class="featured-collection__content">

      {% if section.settings.eyebrow != blank %}
        <p class="featured-collection__eyebrow">
          {{ section.settings.eyebrow | escape }}
        </p>
      {% endif %}


      <h2 class="featured-collection__heading">
        {{ section.settings.heading }}
      </h2>


      {% if section.settings.description != blank %}
        <div class="featured-collection__description">
          {{ section.settings.description }}
        </div>
      {% endif %}


      {% if section.settings.collection != blank %}

        <a
          class="featured-collection__button"
          href="{{ section.settings.collection.url }}"
        >
          {{ section.settings.button_label | escape }}
        </a>

      {% endif %}

    </div>


  </div>

</section>
{% stylesheet %}

  .featured-collection {
    width: 100%;
    padding: 72px 0;
    background: var(--featured-background);
    color: var(--featured-text);
  }


  .featured-collection__inner {
    position: relative;
    width: min(100% - 32px, 1400px);
    min-height: var(--featured-height);
    margin: 0 auto;
    overflow: hidden;
    border-radius: 28px;
  }


  .featured-collection__banner {
    position: absolute;
    inset: 0;
  }


  .featured-collection__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }


  .featured-collection__banner::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.25);
  }


  .featured-collection__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: var(--featured-height);
    padding: 50px 30px;
    text-align: center;
    color: white;
  }


  .featured-collection__eyebrow {
    margin: 0 0 14px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }


  .featured-collection__heading {
    max-width: 900px;
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1;
  }


  .featured-collection__description {
    max-width: 650px;
    margin-top: 20px;
    font-size: 1.05rem;
    line-height: 1.7;
  }


  .featured-collection__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 28px;
    padding: 14px 32px;
    border-radius: 999px;
    background: white;
    color: #402733;
    font-weight: 700;
    text-decoration: none;
    transition: transform 180ms ease;
  }


  .featured-collection__button:hover {
    transform: translateY(-2px);
  }



  @media screen and (max-width: 749px) {

    .featured-collection {
      padding: 52px 0;
    }


    .featured-collection__inner {
      min-height: var(--featured-height-mobile);
      border-radius: 20px;
    }


    .featured-collection__content {
      min-height: var(--featured-height-mobile);
      padding: 40px 24px;
    }


    .featured-collection__heading {
      font-size: clamp(2rem, 10vw, 3.5rem);
    }


    .featured-collection__description {
      font-size: 1rem;
    }

  }


{% endstylesheet %}
{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop collection image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile collection image"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Desktop section height",
      "min": 300,
      "max": 900,
      "step": 25,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "label": "Mobile section height",
      "min": 250,
      "max": 700,
      "step": 25,
      "unit": "px",
      "default": 450
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small heading",
      "default": "Featured Collection"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Explore our favorites"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Highlight your most-loved products and collections.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop collection"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8e8ef"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
