<header
  class="site-header{% if section.settings.sticky_header %} site-header--sticky{% endif %}"
  style="
    --header-background: {{ section.settings.background_color }};
    --header-text: {{ section.settings.text_color }};
    --logo-width: {{ settings.logo_width }}px;
  "
>
  <div class="site-header__inner">

    <details class="mobile-navigation">
      <summary class="header-icon" aria-label="Open menu">
        <span></span>
        <span></span>
        <span></span>
      </summary>

      <nav class="mobile-navigation__drawer" aria-label="Mobile navigation">
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}">
            {{ link.title | escape }}
          </a>

          {% if link.links != blank %}
            <div class="mobile-navigation__submenu">
              {% for child_link in link.links %}
                <a href="{{ child_link.url }}">
                  {{ child_link.title | escape }}
                </a>
              {% endfor %}
            </div>
          {% endif %}
        {% endfor %}
      </nav>
    </details>


    <a class="site-header__logo" href="{{ routes.root_url }}">
      {% if settings.logo != blank %}
        {{
          settings.logo
          | image_url: width: settings.logo_width
          | image_tag:
            loading: 'eager',
            widths: '100, 150, 200, 250, 300, 400',
            alt: shop.name
        }}
      {% else %}
        <span>{{ shop.name | escape }}</span>
      {% endif %}
    </a>


    <nav class="desktop-navigation" aria-label="Main navigation">
      {% for link in section.settings.menu.links %}
        <div class="desktop-navigation__item">

          <a href="{{ link.url }}">
            {{ link.title | escape }}
          </a>

          {% if link.links != blank %}
            <div class="desktop-navigation__dropdown">
              {% for child_link in link.links %}
                <a href="{{ child_link.url }}">
                  {{ child_link.title | escape }}
                </a>
              {% endfor %}
            </div>
          {% endif %}

        </div>
      {% endfor %}
    </nav>


    <div class="site-header__icons">

      {% if section.settings.show_search %}
        <a
          class="header-icon"
          href="{{ routes.search_url }}"
          aria-label="Search"
        >
          {{ 'icon-search.svg' | inline_asset_content }}
        </a>
      {% endif %}

      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a
        class="header-icon site-header__cart"
        href="{{ routes.cart_url }}"
        aria-label="Cart"
      >
        {{ 'icon-cart.svg' | inline_asset_content }}

        {% if cart.item_count > 0 %}
          <span class="site-header__cart-count">
            {{ cart.item_count }}
          </span>
        {% endif %}
      </a>

    </div>

  </div>
</header>
{% stylesheet %}
  .site-header {
    position: relative;
    z-index: 30;
    width: 100%;
    background: var(--header-background);
    color: var(--header-text);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .site-header--sticky {
    position: sticky;
    top: 0;
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    width: min(100% - 32px, 1400px);
    min-height: 72px;
    margin: 0 auto;
    gap: 24px;
  }

  .site-header a {
    color: inherit;
    text-decoration: none;
  }

  .site-header__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .site-header__logo img {
    display: block;
    width: var(--logo-width);
    max-width: 100%;
    height: auto;
  }

  .desktop-navigation {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  .desktop-navigation__item {
    position: relative;
  }

  .desktop-navigation__item > a {
    display: block;
    padding: 25px 0;
    font-size: 0.95rem;
  }

  .desktop-navigation__dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    display: none;
    min-width: 190px;
    padding: 12px;
    background: var(--header-background);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.12);
    transform: translateX(-50%);
  }

  .desktop-navigation__dropdown a {
    display: block;
    padding: 10px 12px;
    border-radius: 8px;
    white-space: nowrap;
  }

  .desktop-navigation__dropdown a:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .desktop-navigation__item:hover .desktop-navigation__dropdown,
  .desktop-navigation__item:focus-within .desktop-navigation__dropdown {
    display: block;
  }

  .site-header__icons {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14px;
  }

  .header-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
  }

  .header-icon svg,
  .site-header__icons shopify-account svg {
    width: 23px;
    height: 23px;
  }

  .site-header__cart-count {
    position: absolute;
    top: 2px;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 999px;
    background: var(--header-text);
    color: var(--header-background);
    font-size: 0.7rem;
    font-weight: 700;
  }

  .mobile-navigation {
    display: none;
  }

  .mobile-navigation summary {
    list-style: none;
  }

  .mobile-navigation summary::-webkit-details-marker {
    display: none;
  }

  .mobile-navigation summary span {
    display: block;
    width: 22px;
    height: 2px;
    margin: 3px 0;
    background: currentColor;
    border-radius: 999px;
  }

  .mobile-navigation__drawer {
    position: absolute;
    top: 100%;
    left: 0;
    width: min(88vw, 360px);
    max-height: calc(100vh - 72px);
    padding: 22px;
    overflow-y: auto;
    background: var(--header-background);
    border-right: 1px solid rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 12px 18px 35px rgba(0, 0, 0, 0.12);
  }

  .mobile-navigation__drawer > a {
    display: block;
    padding: 13px 0;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .mobile-navigation__submenu {
    padding: 0 0 8px 16px;
  }

  .mobile-navigation__submenu a {
    display: block;
    padding: 9px 0;
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {

    .site-header__inner {
      grid-template-columns: auto 1fr auto;
      min-height: 64px;
      gap: 12px;
    }

    .mobile-navigation {
      display: block;
    }

    .desktop-navigation {
      display: none;
    }

    .site-header__logo {
      justify-content: center;
      text-align: center;
    }

    .site-header__icons {
      gap: 2px;
    }

    .site-header__icons > a:first-child {
      display: none;
    }

    .header-icon {
      width: 38px;
      height: 38px;
    }

  }
{% endstylesheet %}
{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "Customer account menu",
      "default": "customer-account-main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Keep header visible while scrolling",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fff8fb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text and icon color",
      "default": "#402733"
    }
  ]
}
{% endschema %}
