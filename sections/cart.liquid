<section class="cart-page">
  <div class="cart-page__inner">
    <div class="cart-page__header">
      <h1>Your cart</h1>

      {% if cart.item_count > 0 %}
        <p>
          {{ cart.item_count }}
          {% if cart.item_count == 1 %}
            item
          {% else %}
            items
          {% endif %}
        </p>
      {% endif %}
    </div>

    {% if cart.item_count > 0 %}
      <form
        class="cart-form"
        action="{{ routes.cart_url }}"
        method="post"
      >
        <div class="cart-items">
          {% for item in cart.items %}
            <article class="cart-item">
              <a
                class="cart-item__image-link"
                href="{{ item.url }}"
              >
                {% if item.image != blank %}
                  {{
                    item.image
                    | image_url: width: 400
                    | image_tag:
                      class: 'cart-item__image',
                      loading: 'lazy',
                      widths: '100, 200, 300, 400',
                      sizes: '140px',
                      alt: item.product.title
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'cart-item__image cart-item__placeholder' }}
                {% endif %}
              </a>

              <div class="cart-item__details">
                {% if section.settings.show_vendor and item.product.vendor != blank %}
                  <p class="cart-item__vendor">
                    {{ item.product.vendor | escape }}
                  </p>
                {% endif %}

                <h2 class="cart-item__title">
                  <a href="{{ item.url }}">
                    {{ item.product.title | escape }}
                  </a>
                </h2>

                {% unless item.product.has_only_default_variant %}
                  <p class="cart-item__variant">
                    {{ item.variant.title | escape }}
                  </p>
                {% endunless %}

                {% if item.properties.size > 0 %}
                  <dl class="cart-item__properties">
                    {% for property in item.properties %}
                      {% assign first_character = property.first | slice: 0 %}

                      {% if property.last != blank and first_character != '_' %}
                        <div>
                          <dt>{{ property.first | escape }}:</dt>
                          <dd>{{ property.last }}</dd>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </dl>
                {% endif %}

                {% if item.line_level_discount_allocations.size > 0 %}
                  <div class="cart-item__discounts">
                    {% for allocation in item.line_level_discount_allocations %}
                      <p>
                        {{ allocation.discount_application.title | escape }}
                        −{{ allocation.amount | money }}
                      </p>
                    {% endfor %}
                  </div>
                {% endif %}

                <a
                  class="cart-item__remove"
                  href="{{ item.url_to_remove }}"
                >
                  Remove
                </a>
              </div>

              <div class="cart-item__quantity">
                <label for="CartQuantity-{{ forloop.index }}">
                  Quantity
                </label>

                <input
                  id="CartQuantity-{{ forloop.index }}"
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  step="1"
                  inputmode="numeric"
                >
              </div>

              <div class="cart-item__price">
                {% if item.original_line_price > item.final_line_price %}
                  <s>{{ item.original_line_price | money }}</s>
                {% endif %}

                <strong>
                  {{ item.final_line_price | money }}
                </strong>
              </div>
            </article>
          {% endfor %}
        </div>

        <div class="cart-summary">
          {% if section.settings.show_note %}
            <div class="cart-summary__note">
              <label for="CartNote-{{ section.id }}">
                Order note
              </label>

              <textarea
                id="CartNote-{{ section.id }}"
                name="note"
                rows="4"
                placeholder="Add special instructions for your order"
              >{{ cart.note }}</textarea>
            </div>
          {% endif %}

          <div class="cart-summary__totals">
            {% if cart.cart_level_discount_applications.size > 0 %}
              <div class="cart-summary__discounts">
                {% for discount in cart.cart_level_discount_applications %}
                  <div class="cart-summary__discount">
                    <span>{{ discount.title | escape }}</span>

                    <span>
                      −{{ discount.total_allocated_amount | money }}
                    </span>
                  </div>
                {% endfor %}
              </div>
            {% endif %}

            <div class="cart-summary__subtotal">
              <span>Subtotal</span>

              <strong>
                {{ cart.items_subtotal_price | money }}
              </strong>
            </div>

            <p class="cart-summary__message">
              Taxes and shipping are calculated at checkout.
            </p>

            <button
              class="cart-summary__update"
              type="submit"
              name="update"
            >
              Update cart
            </button>

            <button
              class="cart-summary__checkout"
              type="submit"
              name="checkout"
            >
              Checkout
            </button>
          </div>
        </div>
      </form>
    {% else %}
      <div class="cart-empty">
        <h2>Your cart is empty</h2>

        <p>Add something lovely and come back when you’re ready.</p>

        <a href="{{ routes.all_products_collection_url }}">
          Continue shopping
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .cart-page {
    width: 100%;
    padding: 56px 0 84px;
  }

  .cart-page__inner {
    width: min(100% - 32px, 1200px);
    margin: 0 auto;
  }

  .cart-page__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 34px;
  }

  .cart-page__header h1 {
    margin: 0;
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 1;
  }

  .cart-page__header p {
    margin: 0;
    opacity: 0.65;
  }

  .cart-items {
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .cart-item {
    display: grid;
    grid-template-columns: 140px minmax(0, 1fr) 120px 130px;
    gap: 24px;
    align-items: center;
    padding: 24px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .cart-item a {
    color: inherit;
    text-decoration: none;
  }

  .cart-item__image-link {
    display: block;
  }

  .cart-item__image {
    display: block;
    width: 140px;
    height: 170px;
    object-fit: cover;
    border-radius: 16px;
    background: rgba(0, 0, 0, 0.04);
  }

  .cart-item__vendor {
    margin: 0 0 6px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .cart-item__title {
    margin: 0;
    font-size: 1.15rem;
  }

  .cart-item__variant {
    margin: 8px 0 0;
    font-size: 0.9rem;
    opacity: 0.65;
  }

  .cart-item__properties {
    margin: 10px 0 0;
    font-size: 0.88rem;
  }

  .cart-item__properties div {
    display: flex;
    gap: 5px;
  }

  .cart-item__properties dt,
  .cart-item__properties dd {
    margin: 0;
  }

  .cart-item__discounts {
    margin-top: 10px;
    font-size: 0.85rem;
  }

  .cart-item__discounts p {
    margin: 4px 0;
  }

  .cart-item__remove {
    display: inline-block;
    margin-top: 14px;
    font-size: 0.88rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.7;
  }

  .cart-item__quantity {
    display: grid;
    gap: 8px;
  }

  .cart-item__quantity label {
    font-size: 0.85rem;
    font-weight: 700;
  }

  .cart-item__quantity input {
    width: 100%;
    min-height: 46px;
    padding: 8px 12px;
    border: 1px solid rgba(0, 0, 0, 0.18);
    border-radius: 10px;
    background: white;
    color: inherit;
    font: inherit;
  }

  .cart-item__price {
    text-align: right;
  }

  .cart-item__price s,
  .cart-item__price strong {
    display: block;
  }

  .cart-item__price s {
    margin-bottom: 5px;
    opacity: 0.5;
  }

  .cart-summary {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 420px);
    gap: 48px;
    margin-top: 40px;
  }

  .cart-summary__note {
    display: grid;
    gap: 10px;
  }

  .cart-summary__note label {
    font-weight: 700;
  }

  .cart-summary__note textarea {
    width: 100%;
    box-sizing: border-box;
    padding: 14px;
    border: 1px solid rgba(0, 0, 0, 0.18);
    border-radius: 14px;
    resize: vertical;
    font: inherit;
  }

  .cart-summary__totals {
    padding: 28px;
    border-radius: 20px;
    background: rgba(0, 0, 0, 0.04);
  }

  .cart-summary__discounts {
    display: grid;
    gap: 8px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .cart-summary__discount {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    font-size: 0.9rem;
  }

  .cart-summary__subtotal {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    font-size: 1.2rem;
  }

  .cart-summary__message {
    margin: 14px 0 22px;
    font-size: 0.88rem;
    line-height: 1.5;
    opacity: 0.65;
  }

  .cart-summary__update,
  .cart-summary__checkout,
  .cart-empty a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 50px;
    box-sizing: border-box;
    padding: 12px 24px;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .cart-summary__update {
    border: 1px solid currentColor;
    background: transparent;
    color: inherit;
  }

  .cart-summary__checkout {
    margin-top: 12px;
    border: 0;
    background: #402733;
    color: white;
  }

  .cart-empty {
    padding: 90px 20px;
    text-align: center;
  }

  .cart-empty h2 {
    margin: 0;
    font-size: 2.2rem;
  }

  .cart-empty p {
    margin: 16px 0 28px;
    opacity: 0.7;
  }

  .cart-empty a {
    display: inline-flex;
    width: auto;
    background: #402733;
    color: white;
    text-decoration: none;
  }

  @media screen and (max-width: 749px) {
    .cart-page {
      padding-top: 36px;
    }

    .cart-page__header {
      align-items: flex-start;
      flex-direction: column;
    }

    .cart-item {
      grid-template-columns: 100px minmax(0, 1fr);
      gap: 16px;
    }

    .cart-item__image {
      width: 100px;
      height: 125px;
    }

    .cart-item__quantity {
      grid-column: 2;
      width: 110px;
    }

    .cart-item__price {
      grid-column: 2;
      text-align: left;
    }

    .cart-summary {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "Show order note",
      "default": true
    }
  ]
}
{% endschema %}

