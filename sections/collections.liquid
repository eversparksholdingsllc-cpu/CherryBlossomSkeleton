<section
  class="collections-page"
  style="
    --collections-background: {{ section.settings.background_color }};
    --collections-text: {{ section.settings.text_color }};
    --collections-columns: {{ section.settings.columns_desktop }};
    --collections-gap: {{ section.settings.grid_gap }}px;
  "
>
  <div class="collections-page__inner">
    <header class="collections-page__header">
      {% if section.settings.eyebrow != blank %}
        <p class="collections-page__eyebrow">
          {{ section.settings.eyebrow | escape }}
        </p>
      {% endif %}

      <h1 class="collections-page__heading">
        {{ section.settings.heading | escape }}
      </h1>

      {% if section.settings.description != blank %}
        <div class="collections-page__description">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </header>

    {% paginate collections by section.settings.collections_per_page %}
      {% if collections.size > 0 %}
        <div class="collections-page__grid">
          {% for collection in collections %}
            <a
              class="collections-page__card"
              href="{{ collection.url }}"
            >
              <div class="collections-page__media">
                {% if collection.featured_image != blank %}
                  {{
                    collection.featured_image
                    | image_url: width: 1400
                    | image_tag:
                      class: 'collections-page__image',
                      loading: 'lazy',
                      widths: '400, 600, 800, 1000, 1200, 1400',
                      sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                      alt: collection.title
                  }}
                {% elsif collection.products.first.featured_image != blank %}
                  {{
                    collection.products.first.featured_image
                    | image_url: width: 1400
                    | image_tag:
                      class: 'collections-page__image',
                      loading: 'lazy',
                      widths: '400, 600, 800, 1000, 1200, 1400',
                      sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                      alt: collection.title
                  }}
                {% else %}
                  {{ 'collection-1' | placeholder_svg_tag: 'collections-page__placeholder' }}
                {% endif %}

                <div class="collections-page__overlay"></div>

                <div class="collections-page__card-content">
                  <h2>
                    {{ collection.title | escape }}
                  </h2>

                  {% if section.settings.show_product_count %}
                    <p class="collections-page__count">
                      {{ collection.products_count }}
                      {% if collection.products_count == 1 %}
                        product
                      {% else %}
                        products
                      {% endif %}
                    </p>
                  {% endif %}
                </div>
              </div>

              {% if section.settings.show_description and collection.description != blank %}
                <div class="collections-page__card-description">
                  {{ collection.description | strip_html | truncatewords: 20 }}
                </div>
              {% endif %}
            </a>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <nav
            class="collections-page__pagination"
            aria-label="Collections pagination"
          >
            {{ paginate | default_pagination }}
          </nav>
        {% endif %}
      {% else %}
        <div class="collections-page__empty">
          <h2>No collections found</h2>
          <p>Create a collection in your Shopify admin to display it here.</p>
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% stylesheet %}
  .collections-page {
    width: 100%;
    padding: 64px 0 84px;
    background: var(--collections-background);
    color: var(--collections-text);
  }

  .collections-page__inner {
    width: min(100% - 32px, 1400px);
    margin: 0 auto;
  }

  .collections-page__header {
    max-width: 760px;
    margin: 0 auto 44px;
    text-align: center;
  }

  .collections-page__eyebrow {
    margin: 0 0 10px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .collections-page__heading {
    margin: 0;
    font-size: clamp(2.6rem, 7vw, 5.5rem);
    line-height: 1;
  }

  .collections-page__description {
    margin-top: 18px;
    line-height: 1.7;
    opacity: 0.78;
  }

  .collections-page__description p {
    margin: 0;
  }

  .collections-page__grid {
    display: grid;
    grid-template-columns: repeat(
      var(--collections-columns),
      minmax(0, 1fr)
    );
    gap: var(--collections-gap);
  }

  .collections-page__card {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .collections-page__media {
    position: relative;
    min-height: 430px;
    overflow: hidden;
    border-radius: 24px;
    background: rgba(0, 0, 0, 0.05);
  }

  .collections-page__image,
  .collections-page__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 430px;
    object-fit: cover;
    transition: transform 350ms ease;
  }

  .collections-page__card:hover .collections-page__image {
    transform: scale(1.04);
  }

  .collections-page__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(35, 18, 27, 0.75),
      rgba(35, 18, 27, 0.05) 65%
    );
  }

  .collections-page__card-content {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    padding: 28px;
    color: white;
  }

  .collections-page__card-content h2 {
    margin: 0;
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    line-height: 1.08;
  }

  .collections-page__count {
    margin: 8px 0 0;
    font-size: 0.9rem;
    opacity: 0.85;
  }

  .collections-page__card-description {
    padding: 16px 4px 0;
    line-height: 1.6;
    opacity: 0.72;
  }

  .collections-page__pagination {
    margin-top: 52px;
    text-align: center;
  }

  .collections-page__pagination .page,
  .collections-page__pagination .next,
  .collections-page__pagination .prev {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 42px;
    min-height: 42px;
    margin: 3px;
    padding: 8px 12px;
    border: 1px solid rgba(0, 0, 0, 0.14);
    border-radius: 999px;
  }

  .collections-page__empty {
    padding: 80px 20px;
    text-align: center;
  }

  .collections-page__empty h2 {
    margin: 0;
    font-size: 2rem;
  }

  .collections-page__empty p {
    margin: 14px 0 0;
  }

  @media screen and (max-width: 989px) {
    .collections-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .collections-page {
      padding: 48px 0 64px;
    }

    .collections-page__header {
      margin-bottom: 32px;
    }

    .collections-page__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .collections-page__media,
    .collections-page__image,
    .collections-page__placeholder {
      min-height: 380px;
    }

    .collections-page__media {
      border-radius: 18px;
    }

    .collections-page__card-content {
      padding: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collections-page__image {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collections grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small heading",
      "default": "Explore our shop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop all collections"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Browse every collection and find something made for you.</p>"
    },
    {
      "type": "range",
      "id": "collections_per_page",
      "label": "Collections per page",
      "min": 6,
      "max": 24,
      "step": 3,
      "default": 12
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Space between cards",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection descriptions",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fffafc"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ],
  "presets": [
    {
      "name": "Collections grid"
    }
  ]
}
{% endschema %}