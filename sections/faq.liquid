<section
  class="faq-section"
  style="
    --faq-background: {{ section.settings.background_color }};
    --faq-text: {{ section.settings.text_color }};
  "
>
  <div class="faq-section__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="faq-section__eyebrow">
        {{ section.settings.eyebrow | escape }}
      </p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="faq-section__heading">
        {{ section.settings.heading | escape }}
      </h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="faq-section__description">
        {{ section.settings.description }}
      </div>
    {% endif %}

    <div class="faq-section__items">
      {% for block in section.blocks %}
        <details
          class="faq-item"
          {% if section.settings.open_first and forloop.first %}
            open
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <summary class="faq-item__question">
            <span>{{ block.settings.question | escape }}</span>

            <span class="faq-item__icon" aria-hidden="true">
              +
            </span>
          </summary>

          <div class="faq-item__answer">
            {{ block.settings.answer }}
          </div>
        </details>
      {% else %}
        <details class="faq-item" open>
          <summary class="faq-item__question">
            <span>How long does shipping take?</span>
            <span class="faq-item__icon" aria-hidden="true">+</span>
          </summary>

          <div class="faq-item__answer">
            <p>Add your shipping information here.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-item__question">
            <span>What is your return policy?</span>
            <span class="faq-item__icon" aria-hidden="true">+</span>
          </summary>

          <div class="faq-item__answer">
            <p>Add your return-policy information here.</p>
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .faq-section {
    width: 100%;
    padding: 72px 0;
    background: var(--faq-background);
    color: var(--faq-text);
  }

  .faq-section__inner {
    width: min(100% - 32px, 900px);
    margin: 0 auto;
  }

  .faq-section__eyebrow {
    margin: 0 0 10px;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .faq-section__heading {
    margin: 0;
    text-align: center;
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 1.05;
  }

  .faq-section__description {
    max-width: 650px;
    margin: 16px auto 36px;
    text-align: center;
    line-height: 1.6;
    opacity: 0.78;
  }

  .faq-section__description p {
    margin: 0;
  }

  .faq-section__items {
    display: grid;
    gap: 14px;
    margin-top: 38px;
  }

  .faq-item {
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.6);
  }

  .faq-item__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 22px 24px;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    list-style: none;
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__icon {
    flex: 0 0 auto;
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1;
    transition: transform 180ms ease;
  }

  .faq-item[open] .faq-item__icon {
    transform: rotate(45deg);
  }

  .faq-item__answer {
    padding: 0 24px 22px;
    line-height: 1.7;
    opacity: 0.8;
  }

  .faq-item__answer p {
    margin: 0 0 1em;
  }

  .faq-item__answer p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .faq-section {
      padding: 52px 0;
    }

    .faq-item__question {
      padding: 19px 18px;
      font-size: 1rem;
    }

    .faq-item__answer {
      padding: 0 18px 19px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item__icon {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-faq",
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small heading",
      "default": "Need help?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Answer common questions about your products, shipping, returns, and store policies.</p>"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first question automatically",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fffafc"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your question?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Add the answer here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "question"
        },
        {
          "type": "question"
        },
        {
          "type": "question"
        }
      ]
    }
  ]
}
{% endschema %}
