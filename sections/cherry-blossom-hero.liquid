<section
  class="cherry-hero"
  style="
    --hero-height: {{ section.settings.hero_height }}px;
    --hero-height-mobile: {{ section.settings.hero_height_mobile }}px;
    --hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>

  <div class="cherry-hero__media">

    {% if section.settings.image_desktop != blank or section.settings.image_mobile != blank %}

      <picture>

        {% if section.settings.image_mobile != blank %}
          <source
            media="(max-width: 749px)"
            srcset="{{ section.settings.image_mobile | image_url: width: 1200 }}"
          >
        {% endif %}


        {% if section.settings.image_desktop != blank %}
          {{
            section.settings.image_desktop
            | image_url: width: 2400
            | image_tag:
              class: 'cherry-hero__image',
              loading: 'eager',
              widths: '750,1000,1500,2000,2400',
              sizes: '100vw',
              alt: section.settings.image_desktop.alt
          }}
        {% endif %}

      </picture>


    {% else %}

      {{ 'lifestyle-2' | placeholder_svg_tag: 'cherry-hero__placeholder' }}

    {% endif %}


    <div class="cherry-hero__overlay"></div>

  </div>


  <div class="
    cherry-hero__content
    cherry-hero__content--{{ section.settings.desktop_alignment }}
    cherry-hero__content-mobile--{{ section.settings.mobile_alignment }}
  ">

    {% if section.settings.eyebrow != blank %}
      <p class="cherry-hero__eyebrow">
        {{ section.settings.eyebrow | escape }}
      </p>
    {% endif %}


    {% if section.settings.heading != blank %}
      <h1 class="cherry-hero__heading">
        {{ section.settings.heading }}
      </h1>
    {% endif %}


    {% if section.settings.text != blank %}
      <div class="cherry-hero__text">
        {{ section.settings.text }}
      </div>
    {% endif %}


    {% if section.settings.button_label != blank %}
      <a
        class="cherry-hero__button"
        href="{{ section.settings.button_link }}"
      >
        {{ section.settings.button_label | escape }}
      </a>
    {% endif %}

  </div>

</section>
{% stylesheet %}

  .cherry-hero {
    position: relative;
    width: 100%;
    height: var(--hero-height);
    overflow: hidden;
    color: white;
  }


  .cherry-hero__media {
    position: absolute;
    inset: 0;
  }


  .cherry-hero__image,
  .cherry-hero__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }


  .cherry-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--hero-overlay));
  }


  .cherry-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: min(100% - 40px, 1400px);
    height: 100%;
    margin: 0 auto;
  }


  .cherry-hero__content--left {
    align-items: flex-start;
    text-align: left;
  }


  .cherry-hero__content--center {
    align-items: center;
    text-align: center;
  }


  .cherry-hero__content--right {
    align-items: flex-end;
    text-align: right;
  }


  .cherry-hero__eyebrow {
    margin: 0 0 16px;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
  }


  .cherry-hero__heading {
    max-width: 900px;
    margin: 0;
    font-size: clamp(2.8rem, 7vw, 6.5rem);
    line-height: 1;
  }


  .cherry-hero__text {
    max-width: 650px;
    margin-top: 22px;
    font-size: 1.1rem;
    line-height: 1.7;
  }


  .cherry-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 32px;
    padding: 14px 34px;
    border-radius: 999px;
    background: white;
    color: #402733;
    font-weight: 700;
    text-decoration: none;
    transition: transform 180ms ease;
  }


  .cherry-hero__button:hover {
    transform: translateY(-2px);
  }



  @media screen and (max-width: 749px) {

    .cherry-hero {
      height: var(--hero-height-mobile);
    }


    .cherry-hero__content {
      width: min(100% - 32px, 600px);
    }


    .cherry-hero__content-mobile--top {
      justify-content: flex-start;
      padding-top: 80px;
    }


    .cherry-hero__content-mobile--center {
      justify-content: center;
    }


    .cherry-hero__content-mobile--bottom {
      justify-content: flex-end;
      padding-bottom: 60px;
    }


    .cherry-hero__heading {
      font-size: clamp(2.2rem, 11vw, 4rem);
    }


    .cherry-hero__text {
      font-size: 1rem;
    }

  }


{% endstylesheet %}
{% schema %}
{
  "name": "Cherry Blossom Hero",
  "tag": "section",
  "class": "section-cherry-blossom-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop hero image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile hero image"
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Desktop hero height",
      "min": 400,
      "max": 900,
      "step": 25,
      "unit": "px",
      "default": 650
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Mobile hero height",
      "min": 300,
      "max": 800,
      "step": 25,
      "unit": "px",
      "default": 550
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 25
    },
    {
      "type": "select",
      "id": "desktop_alignment",
      "label": "Desktop text position",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Mobile text position",
      "default": "center",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small heading",
      "default": "Welcome"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Beautiful moments start here"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Create a soft and elegant first impression for your brand.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Cherry Blossom Hero"
    }
  ]
}
{% endschema %}
