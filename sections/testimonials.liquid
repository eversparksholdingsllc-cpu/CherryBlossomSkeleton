<section
  class="testimonials"
  style="
    --testimonials-background: {{ section.settings.background_color }};
    --testimonials-text: {{ section.settings.text_color }};
    --testimonials-height: {{ section.settings.section_height }}px;
    --testimonials-height-mobile: {{ section.settings.section_height_mobile }}px;
  "
>

  <div class="testimonials__media">

    {% if section.settings.image_desktop != blank or section.settings.image_mobile != blank %}

      <picture>

        {% if section.settings.image_mobile != blank %}
          <source
            media="(max-width: 749px)"
            srcset="{{ section.settings.image_mobile | image_url: width: 1200 }}"
          >
        {% endif %}


        {% if section.settings.image_desktop != blank %}
          {{
            section.settings.image_desktop
            | image_url: width: 2000
            | image_tag:
              class: 'testimonials__image',
              loading: 'lazy',
              widths: '750,1000,1500,2000',
              sizes: '100vw',
              alt: section.settings.image_desktop.alt
          }}
        {% endif %}

      </picture>

    {% endif %}


    <div class="testimonials__overlay"></div>

  </div>



  <div class="testimonials__inner">

    {% if section.settings.heading != blank %}
      <h2 class="testimonials__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}


    <div class="testimonials__grid">

      {% for block in section.blocks %}

        <article
          class="testimonial-card"
          {{ block.shopify_attributes }}
        >

          {% if block.settings.quote != blank %}
            <div class="testimonial-card__quote">
              {{ block.settings.quote }}
            </div>
          {% endif %}


          {% if block.settings.name != blank %}
            <p class="testimonial-card__name">
              {{ block.settings.name }}
            </p>
          {% endif %}

        </article>

      {% endfor %}

    </div>

  </div>

</section>
{% stylesheet %}

  .testimonials {
    position: relative;
    width: 100%;
    min-height: var(--testimonials-height);
    overflow: hidden;
    background: var(--testimonials-background);
    color: var(--testimonials-text);
  }


  .testimonials__media {
    position: absolute;
    inset: 0;
  }


  .testimonials__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }


  .testimonials__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
  }


  .testimonials__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: min(100% - 32px, 1400px);
    min-height: var(--testimonials-height);
    margin: 0 auto;
    padding: 72px 0;
  }


  .testimonials__heading {
    margin: 0 0 40px;
    text-align: center;
    color: white;
    font-size: clamp(2rem, 5vw, 4rem);
  }


  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }


  .testimonial-card {
    padding: 34px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.92);
    color: #402733;
    backdrop-filter: blur(8px);
  }


  .testimonial-card__quote {
    font-size: 1.05rem;
    line-height: 1.7;
  }


  .testimonial-card__name {
    margin: 20px 0 0;
    font-weight: 700;
  }



  @media screen and (max-width: 989px) {

    .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }

  }



  @media screen and (max-width: 749px) {

    .testimonials {
      min-height: var(--testimonials-height-mobile);
    }


    .testimonials__inner {
      min-height: var(--testimonials-height-mobile);
      padding: 52px 0;
    }


    .testimonials__grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }


    .testimonial-card {
      padding: 26px;
      border-radius: 18px;
    }


    .testimonials__heading {
      margin-bottom: 28px;
    }

  }

{% endstylesheet %}
{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile background image"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Desktop section height",
      "min": 350,
      "max": 900,
      "step": 25,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "label": "Mobile section height",
      "min": 300,
      "max": 800,
      "step": 25,
      "unit": "px",
      "default": 500
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Loved by our customers"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F8DDEB"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "richtext",
          "id": "quote",
          "label": "Customer quote",
          "default": "<p>Absolutely beautiful quality. I love everything about it.</p>"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Happy customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}
