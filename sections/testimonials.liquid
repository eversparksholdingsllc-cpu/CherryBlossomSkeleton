<section
  class="testimonials"
  style="
    --testimonials-background: {{ section.settings.background_color }};
    --testimonials-text: {{ section.settings.text_color }};
    --testimonials-columns: {{ section.settings.columns_desktop }};
  "
>
  <div class="testimonials__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="testimonials__eyebrow">
        {{ section.settings.eyebrow | escape }}
      </p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="testimonials__heading">
        {{ section.settings.heading | escape }}
      </h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="testimonials__description">
        {{ section.settings.description }}
      </div>
    {% endif %}

    <div class="testimonials__grid">
      {% for block in section.blocks %}
        <article
          class="testimonial-card"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.show_stars %}
            <div
              class="testimonial-card__stars"
              aria-label="{{ block.settings.rating }} out of 5 stars"
            >
              {% for star in (1..5) %}
                <span
                  {% if star > block.settings.rating %}
                    class="testimonial-card__star--empty"
                  {% endif %}
                >
                  ★
                </span>
              {% endfor %}
            </div>
          {% endif %}

          {% if block.settings.quote != blank %}
            <blockquote class="testimonial-card__quote">
              {{ block.settings.quote }}
            </blockquote>
          {% endif %}

          <div class="testimonial-card__customer">
            {% if block.settings.customer_image != blank %}
              {{
                block.settings.customer_image
                | image_url: width: 160
                | image_tag:
                  class: 'testimonial-card__image',
                  loading: 'lazy',
                  widths: '80, 120, 160',
                  sizes: '64px',
                  alt: block.settings.customer_name
              }}
            {% endif %}

            <div>
              {% if block.settings.customer_name != blank %}
                <p class="testimonial-card__name">
                  {{ block.settings.customer_name | escape }}
                </p>
              {% endif %}

              {% if block.settings.customer_details != blank %}
                <p class="testimonial-card__details">
                  {{ block.settings.customer_details | escape }}
                </p>
              {% endif %}
            </div>
          </div>
        </article>
      {% else %}
        {% for placeholder_number in (1..3) %}
          <article class="testimonial-card">
            <div class="testimonial-card__stars" aria-label="5 out of 5 stars">
              ★★★★★
            </div>

            <blockquote class="testimonial-card__quote">
              <p>
                Add a customer review here to build trust and show why people
                love your products.
              </p>
            </blockquote>

            <p class="testimonial-card__name">
              Happy customer {{ placeholder_number }}
            </p>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .testimonials {
    width: 100%;
    padding: 72px 0;
    background: var(--testimonials-background);
    color: var(--testimonials-text);
  }

  .testimonials__inner {
    width: min(100% - 32px, 1400px);
    margin: 0 auto;
  }

  .testimonials__eyebrow {
    margin: 0 0 10px;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .testimonials__heading {
    margin: 0;
    text-align: center;
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 1.05;
  }

  .testimonials__description {
    max-width: 650px;
    margin: 16px auto 36px;
    text-align: center;
    line-height: 1.6;
    opacity: 0.78;
  }

  .testimonials__description p {
    margin: 0;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(var(--testimonials-columns), minmax(0, 1fr));
    gap: 24px;
    margin-top: 38px;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 30px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.62);
    box-shadow: 0 14px 36px rgba(72, 39, 53, 0.06);
  }

  .testimonial-card__stars {
    display: flex;
    gap: 3px;
    color: #b96f87;
    font-size: 1.05rem;
    letter-spacing: 0.08em;
  }

  .testimonial-card__star--empty {
    opacity: 0.25;
  }

  .testimonial-card__quote {
    flex-grow: 1;
    margin: 22px 0 28px;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .testimonial-card__quote p {
    margin: 0;
  }

  .testimonial-card__customer {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .testimonial-card__image {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 50%;
  }

  .testimonial-card__name {
    margin: 0;
    font-weight: 700;
  }

  .testimonial-card__details {
    margin: 4px 0 0;
    font-size: 0.88rem;
    opacity: 0.65;
  }

  @media screen and (max-width: 989px) {
    .testimonials__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .testimonials {
      padding: 52px 0;
    }

    .testimonials__grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .testimonial-card {
      padding: 24px;
      border-radius: 18px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Small heading",
      "default": "Loved by our customers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What people are saying"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Share real customer experiences and build trust with new shoppers.</p>"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fff8fb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Show star rating",
          "default": true
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "richtext",
          "id": "quote",
          "label": "Review",
          "default": "<p>This product is beautiful, thoughtfully made, and even better than I expected.</p>"
        },
        {
          "type": "image_picker",
          "id": "customer_image",
          "label": "Customer image"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer name",
          "default": "Customer name"
        },
        {
          "type": "text",
          "id": "customer_details",
          "label": "Customer details",
          "default": "Verified buyer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}
