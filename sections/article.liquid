<section
  class="article-page"
  style="
    --article-background: {{ section.settings.background_color }};
    --article-text: {{ section.settings.text_color }};
    --article-width: {{ section.settings.content_width }}px;
  "
>
  <article class="article-page__inner">
    <header class="article-page__header">
      {% if section.settings.show_blog_title %}
        <a class="article-page__blog-link" href="{{ blog.url }}">
          {{ blog.title | escape }}
        </a>
      {% endif %}

      <h1>{{ article.title | escape }}</h1>

      {% if section.settings.show_date or section.settings.show_author %}
        <div class="article-page__metadata">
          {% if section.settings.show_date %}
            <span>
              {{ article.published_at | date: '%B %d, %Y' }}
            </span>
          {% endif %}

          {% if section.settings.show_author %}
            <span>
              By {{ article.author | escape }}
            </span>
          {% endif %}
        </div>
      {% endif %}
    </header>

    {% if article.image != blank and section.settings.show_featured_image %}
      <div class="article-page__featured-media">
        {{
          article.image
          | image_url: width: 2200
          | image_tag:
            class: 'article-page__featured-image',
            loading: 'eager',
            widths: '600, 900, 1200, 1600, 2000, 2200',
            sizes: '100vw',
            alt: article.title
        }}
      </div>
    {% endif %}

    <div class="article-page__content rte">
      {{ article.content }}
    </div>

    {% if article.tags.size > 0 and section.settings.show_tags %}
      <div class="article-page__tags">
        <span>Filed under:</span>

        {% for tag in article.tags %}
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}">
            {{ tag | escape }}
          </a>
        {% endfor %}
      </div>
    {% endif %}

    <nav class="article-page__navigation" aria-label="Article navigation">
      {% if blog.previous_article %}
        <a href="{{ blog.previous_article.url }}">
          <span>Previous article</span>
          <strong>{{ blog.previous_article.title | escape }}</strong>
        </a>
      {% endif %}

      {% if blog.next_article %}
        <a href="{{ blog.next_article.url }}">
          <span>Next article</span>
          <strong>{{ blog.next_article.title | escape }}</strong>
        </a>
      {% endif %}
    </nav>

    {% if blog.comments_enabled? %}
      <section class="article-comments" id="comments">
        <h2>
          Comments
          {% if article.comments_count > 0 %}
            ({{ article.comments_count }})
          {% endif %}
        </h2>

        {% paginate article.comments by 10 %}
          {% if article.comments.size > 0 %}
            <div class="article-comments__list">
              {% for comment in article.comments %}
                <article class="article-comment">
                  <div class="article-comment__header">
                    <strong>{{ comment.author | escape }}</strong>

                    <time datetime="{{ comment.created_at | date: '%Y-%m-%d' }}">
                      {{ comment.created_at | date: '%B %d, %Y' }}
                    </time>
                  </div>

                  <div class="article-comment__content">
                    {{ comment.content }}
                  </div>
                </article>
              {% endfor %}
            </div>
          {% endif %}

          {% if paginate.pages > 1 %}
            <nav
              class="article-comments__pagination"
              aria-label="Comment pagination"
            >
              {{ paginate | default_pagination: anchor: 'comments' }}
            </nav>
          {% endif %}
        {% endpaginate %}

        {% form 'new_comment', article, class: 'article-comment-form' %}
          <h2>Leave a comment</h2>

          {% if form.posted_successfully? %}
            <p class="article-comment-form__message" tabindex="-1">
              Your comment was submitted successfully.
            </p>
          {% endif %}

          {% if form.errors %}
            <div class="article-comment-form__message">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <div class="article-comment-form__grid">
            <div class="article-comment-form__field">
              <label for="CommentAuthor-{{ section.id }}">
                Name
              </label>

              <input
                id="CommentAuthor-{{ section.id }}"
                type="text"
                name="comment[author]"
                value="{{ form.author }}"
                autocomplete="name"
                required
              >
            </div>

            <div class="article-comment-form__field">
              <label for="CommentEmail-{{ section.id }}">
                Email
              </label>

              <input
                id="CommentEmail-{{ section.id }}"
                type="email"
                name="comment[email]"
                value="{{ form.email }}"
                autocomplete="email"
                required
              >
            </div>
          </div>

          <div class="article-comment-form__field">
            <label for="CommentBody-{{ section.id }}">
              Comment
            </label>

            <textarea
              id="CommentBody-{{ section.id }}"
              name="comment[body]"
              rows="7"
              required
            >{{ form.body }}</textarea>
          </div>

          <button type="submit">
            Post comment
          </button>
        {% endform %}
      </section>
    {% endif %}
  </article>
</section>

{% stylesheet %}
  .article-page {
    width: 100%;
    padding: 58px 0 84px;
    background: var(--article-background);
    color: var(--article-text);
  }

  .article-page__inner {
    width: min(100% - 32px, var(--article-width));
    margin: 0 auto;
  }

  .article-page__header {
    max-width: 900px;
    margin: 0 auto 38px;
    text-align: center;
  }

  .article-page__blog-link {
    display: inline-block;
    margin-bottom: 16px;
    color: inherit;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-decoration: none;
    text-transform: uppercase;
    opacity: 0.65;
  }

  .article-page__header h1 {
    margin: 0;
    font-size: clamp(2.6rem, 7vw, 5.8rem);
    line-height: 1;
  }

  .article-page__metadata {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px 18px;
    margin-top: 20px;
    font-size: 0.85rem;
    opacity: 0.65;
  }

  .article-page__featured-media {
    margin-bottom: 46px;
    overflow: hidden;
    border-radius: 26px;
  }

  .article-page__featured-image {
    display: block;
    width: 100%;
    max-height: 760px;
    object-fit: cover;
  }

  .article-page__content {
    font-size: 1.08rem;
    line-height: 1.85;
  }

  .article-page__content p {
    margin: 0 0 1.4em;
  }

  .article-page__content h2,
  .article-page__content h3,
  .article-page__content h4 {
    margin-top: 1.8em;
    margin-bottom: 0.7em;
    line-height: 1.2;
  }

  .article-page__content h2 {
    font-size: clamp(1.9rem, 4vw, 3rem);
  }

  .article-page__content h3 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
  }

  .article-page__content img {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 38px auto;
    border-radius: 20px;
  }

  .article-page__content blockquote {
    margin: 36px 0;
    padding: 24px 28px;
    border-left: 4px solid currentColor;
    border-radius: 0 16px 16px 0;
    background: rgba(0, 0, 0, 0.04);
    font-size: 1.2rem;
  }

  .article-page__content a {
    color: inherit;
    text-underline-offset: 4px;
  }

  .article-page__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 44px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .article-page__tags span {
    font-weight: 700;
  }

  .article-page__tags a {
    color: inherit;
  }

  .article-page__navigation {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-top: 44px;
  }

  .article-page__navigation a {
    display: grid;
    gap: 7px;
    padding: 22px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 16px;
    color: inherit;
    text-decoration: none;
  }

  .article-page__navigation span {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .article-comments {
    margin-top: 70px;
    padding-top: 42px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .article-comments > h2,
  .article-comment-form h2 {
    margin: 0 0 28px;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
  }

  .article-comments__list {
    display: grid;
    gap: 18px;
  }

  .article-comment {
    padding: 24px;
    border-radius: 16px;
    background: rgba(0, 0, 0, 0.04);
  }

  .article-comment__header {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 14px;
  }

  .article-comment__header time {
    font-size: 0.85rem;
    opacity: 0.6;
  }

  .article-comment__content {
    line-height: 1.7;
  }

  .article-comments__pagination {
    margin-top: 32px;
    text-align: center;
  }

  .article-comment-form {
    display: grid;
    gap: 20px;
    margin-top: 54px;
    padding: 30px;
    border-radius: 20px;
    background: rgba(0, 0, 0, 0.04);
  }

  .article-comment-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .article-comment-form__field {
    display: grid;
    gap: 8px;
  }

  .article-comment-form__field label {
    font-weight: 700;
  }

  .article-comment-form__field input,
  .article-comment-form__field textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid rgba(0, 0, 0, 0.16);
    border-radius: 12px;
    background: white;
    color: inherit;
    font: inherit;
  }

  .article-comment-form button {
    min-height: 50px;
    padding: 12px 24px;
    border: 0;
    border-radius: 999px;
    background: var(--article-text);
    color: var(--article-background);
    font-weight: 700;
    cursor: pointer;
  }

  .article-comment-form__message {
    margin: 0;
    padding: 14px 16px;
    border-radius: 12px;
    background: rgba(0, 0, 0, 0.06);
  }

  @media screen and (max-width: 749px) {
    .article-page {
      padding: 42px 0 64px;
    }

    .article-page__featured-media {
      margin-bottom: 34px;
      border-radius: 18px;
    }

    .article-page__content {
      font-size: 1rem;
      line-height: 1.75;
    }

    .article-page__navigation {
      grid-template-columns: 1fr;
    }

    .article-comment-form__grid {
      grid-template-columns: 1fr;
    }

    .article-comment-form {
      padding: 22px;
    }

    .article-comment__header {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Article",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_blog_title",
      "label": "Show blog title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_featured_image",
      "label": "Show featured image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show publication date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show article tags",
      "default": true
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 650,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 900
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fffafc"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#402733"
    }
  ]
}
{% endschema %}
