        "type": "color",
        "id": "color_background",
        "label": "Page background",
        "default": "#FFF9FC"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Section background",
        "default": "#F8DDEB"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Primary accent",
        "default": "#BFA6E8"
